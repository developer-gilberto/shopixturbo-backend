SHOPEE_PARTNER_KEY=mock-partner-key-for-testing
SHOPEE_MAIN_ACCOUNT_ID=123456
SHOPEE_AUTH_PARTNER_HOST="https://openplatform.sandbox.test-stable.shopee.sg"

# Domínio do Frontend
