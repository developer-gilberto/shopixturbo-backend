# Ambiente
NODE_ENV=test

# Servidor
PORT=8000

# URLs
FRONTEND_URL=http://localhost:3000
BASE_API_URL=http://localhost:8000/api/v1

# Banco de dados
DATABASE_URL=postgresql://postgres:test@localhost:5432/shopixturbo-test
POSTGRES_USER=postgres
POSTGRES_PASSWORD=test
POSTGRES_DB=shopixturbo-test

# JWT
JWT_SECRET=test_jwt_secret_key_that_is_at_least_32_characters_long
JWT_EXPIRES_IN=1d

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# Shopee
