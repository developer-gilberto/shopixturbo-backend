generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = ""
  moduleFormat        = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                                  String    @id @default(uuid())
  name                                String
  email                               String    @unique
  password                            String
  role                                UserRole  @default(USER)
  is_email_verified                   Boolean   @default(false)
  email_verification_token            String?
  email_verification_token_expires_at DateTime?
  created_at                          DateTime  @default(now())
  updated_at                          DateTime  @updatedAt

  shops Shop[]

  @@map("users")
}

enum UserRole {
  USER
  ADMIN
}

enum ShopStatus {
  NORMAL
  BANNED
  FROZEN
}

model Shop {
  id                       String          @id @default(uuid())
  name                     String
  description              String?
  shop_logo                String?
  marketplace              MarketplaceType
  external_id              String?
  authorization_expiration DateTime?
  authorized_in            DateTime?
  status                   ShopStatus
  invoice_issuer           String?
  region                   String?
  deleted_at               DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  user_id String
  user    User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  marketplace_token MarketplaceToken?

  @@index([user_id, marketplace])
  @@index([user_id])
  @@map("shops")
}

enum MarketplaceType {
  SHOPEE
  MERCADO_LIVRE
  AMAZON
}

model MarketplaceToken {
  id               String    @id @default(uuid())
  access_token     String
  refresh_token    String?
  external_shop_id String
  expires_at       DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  shop_id String @unique
  shop    Shop   @relation(fields: [shop_id], references: [id], onDelete: Cascade)

  @@map("marketplace_tokens")
}
